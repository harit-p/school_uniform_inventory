{
  "version": 2,
  "installCommand": "npm run install:all",
  "buildCommand": "npm run build --prefix client",
  "outputDirectory": "client/dist",
  "routes": [
    { "src": "/api/(.*)", "dest": "api/index.mjs" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}

